# Dependencies
node_modules/
.pnp
.pnp.js

# Next.js build output
.next/
out/

# Environment files — NEVER commit these
.env.local
.env.*.local

# Ignore any per-project local envs
**/.env.local

# Local Claude Code settings that may contain MCP API keys
# (settings.local.json should never be committed)
**/.claude/settings.local.json

# Seed script secrets (local file expected, not committed)
scripts/*.secrets.json

# Vercel local env previews
.vercel/.env*

# .env.example IS committed (it's a template with no real values)

# Production builds
build/
dist/

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts

# CodexQC reports — local handoff artifacts, not for commit
.codex-qc/

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# Testing
coverage/
.nyc_output/

# Misc
*.pem

# Scaffold temp dir (can be deleted when Windows releases the handle)
nextinit/

# Superpowers plugin workspace (local brainstorming artifacts)
.superpowers/

# Claude Code local settings (machine-specific permissions)
.claude/

# Supabase CLI temp files
supabase/.temp/

.vercel
