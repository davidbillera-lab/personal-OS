# .env.example — Mission Control
# Committed template. Copy to .env.local and fill in real values.
# NEVER put real keys in this file.

# Supabase (get from: supabase.com → project → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Anthropic (get from: console.anthropic.com → API Keys)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (get from: platform.openai.com → API Keys)
OPENAI_API_KEY=sk-...

# Google AI (get from: aistudio.google.com → Get API Key)
GOOGLE_AI_API_KEY=AIza...

# GitHub (get from: github.com → Settings → Developer settings → PATs → Fine-grained)
# Scope needed: Contents (read-only) on repos you want the OS to read
GITHUB_PERSONAL_ACCESS_TOKEN=github_pat_...
GITHUB_USERNAME=davidbillera-lab

# App — update to your Vercel URL in production
NEXT_PUBLIC_APP_URL=http://localhost:3000
